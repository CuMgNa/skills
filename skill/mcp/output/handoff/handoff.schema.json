{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QA Pipeline Handoff",
  "description": "Agent1 → Agent2 交接契约，由 qa-agent-defect-intake 写入，qa-agent-report-publish / qa-orchestrator 读取",
  "type": "object",
  "required": ["projectName", "timestamp", "bugsCreated", "bugsFailed", "screenshotPaths"],
  "properties": {
    "projectName": {
      "type": "string",
      "description": "禅道项目名称（模糊匹配子串）",
      "examples": ["【磐钴】位置监控平台-国际化"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 时间，Agent1 完成时刻"
    },
    "screenshotPaths": {
      "type": "array",
      "items": { "type": "string" },
      "description": "本次处理的截图绝对路径列表"
    },
    "bugsCreated": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": { "type": "integer" },
          "title": { "type": "string" },
          "url": { "type": "string" },
          "severity": { "type": "integer" },
          "pri": { "type": "integer" }
        }
      }
    },
    "bugsFailed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    "reportOptions": {
      "type": "object",
      "properties": {
        "noClosed": { "type": "boolean", "default": true },
        "openedBuild": { "type": "string" },
        "publishNotion": {
          "type": "boolean",
          "default": false,
          "description": "是否在钉钉之外同步写入 Notion"
        },
        "notionParentPageId": {
          "type": "string",
          "format": "uuid",
          "description": "Notion 父页面 ID（子页面模式，首选）"
        },
        "notionDatabaseId": {
          "type": "string",
          "format": "uuid",
          "description": "Notion 数据库 ID（数据库条目模式）"
        },
        "notionTitleProperty": {
          "type": "string",
          "default": "Name",
          "description": "数据库模式下标题属性名"
        },
        "notionTemplatePageId": {
          "type": "string",
          "format": "uuid",
          "default": "c1b23699-3b3b-4b06-b2ac-0ec9ede194b6",
          "description": "样板页 ID（v3新增，用于 Notion 写入时的版式参考）"
        },
        "notionMaterialPageIds": {
          "type": "array",
          "items": { "type": "string", "format": "uuid" },
          "description": "用户指定的辅助测试资料页 ID 数组（第二部分执行表数据来源；为空则隐藏第二部分）"
        },
        "reportMode": {
          "type": "string",
          "enum": ["create-new", "overwrite", "fail-on-duplicate"],
          "default": "create-new",
          "description": "Notion 写入幂等模式：create-new=每次新建 / overwrite=草稿覆盖 / fail-on-duplicate=重复报错"
        },
        "reportMeta": {
          "type": "object",
          "description": "报告元信息（v3新增，用于填充报告信息 callout）",
          "properties": {
            "testType": {
              "type": "string",
              "description": "测试类型，如「第二轮功能测试 + 缺陷回归」"
            },
            "coverageStart": {
              "type": "string",
              "format": "date",
              "description": "覆盖期起始日期"
            },
            "coverageEnd": {
              "type": "string",
              "format": "date",
              "description": "覆盖期截止日期"
            },
            "tester": {
              "type": "string",
              "description": "测试人姓名（如「童美娜」）"
            },
            "developer": {
              "type": "string",
              "description": "开发者姓名（可选）"
            }
          }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
